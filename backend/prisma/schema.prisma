generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EVALUATION
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EscrowStatus {
  PENDING
  PAYMENT_PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  BRAND
  INFLUENCER
  ADMIN
}

model User {
  id                    String             @id @default(auto()) @map("_id") @db.ObjectId
  email                 String             @unique
  password              String
  name                  String
  role                  Role               @default(INFLUENCER)
  verificationStatus    VerificationStatus @default(PENDING)
  emailVerified         Boolean            @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  campaigns          Campaign[]
  influencerProfile  InfluencerProfile?
  brandProfile       BrandProfile?
  applications       Application[]
  adminActions       AdminAction[]
}

model InfluencerProfile {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  userId            String             @unique @db.ObjectId
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String
  bio               String?
  profileImage      String?
  youtubeChannelUrl String?
  youtubeChannelId  String?
  subscriberCount   Int?
  categoryTags      String[]
  pastWorkLinks     String[]
  identityDocument  String?
  verificationNotes String?
  verifiedAt        DateTime?
  verifiedBy        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  applications      Application[]
  influencerReports InfluencerReport[]
}

model BrandProfile {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  userId            String        @unique @db.ObjectId
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName       String
  logo              String?
  website           String?
  industry          String?
  gstNumber         String?
  panNumber         String?
  businessDocument  String?
  verificationNotes String?
  verifiedAt        DateTime?
  verifiedBy        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  brandReports      BrandReport[]
}

model Campaign {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  description         String
  startDate           DateTime
  endDate             DateTime
  budget              Float
  status              CampaignStatus     @default(DRAFT)
  categoryTags        String[]
  contentRequirements String?
  rules               String?
  resultsDate         DateTime?
  evaluationCriteria  Json?
  prizeDistribution   Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  brandId             String             @db.ObjectId
  brand               User               @relation(fields: [brandId], references: [id])
  submissions         Submission[]
  escrow              Escrow?
  applications        Application[]
  referralLinks       ReferralLink[]
  leaderboard         LeaderboardEntry[]
  brandReports        BrandReport[]
}

model Escrow {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  campaignId       String       @unique @db.ObjectId
  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  amount           Float        // Security deposit (25%)
  totalPrizePool   Float?       // Total prize pool
  status           EscrowStatus @default(PENDING)
  paymentReference String?
  paymentMethod    String?
  fundedAt         DateTime?
  releasedAt       DateTime?
  verifiedBy       String?
  notes            String?
  releaseDetails   Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Application {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  campaignId        String            @db.ObjectId
  campaign          Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencerId      String            @db.ObjectId
  influencer        User              @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  influencerProfile InfluencerProfile @relation(fields: [influencerId], references: [userId], onDelete: Cascade)
  status            ApplicationStatus @default(PENDING)
  pitch             String
  proposedContent   String?
  rejectionReason   String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  referralLink      ReferralLink?

  @@unique([campaignId, influencerId])
}

model ReferralLink {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  uniqueCode    String      @unique
  url           String      @unique
  campaignId    String      @db.ObjectId
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  applicationId String      @unique @db.ObjectId
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  totalClicks   Int         @default(0)
  uniqueClicks  Int         @default(0)
  conversions   Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  clicks        Click[]
}

model Click {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  referralLinkId String       @db.ObjectId
  referralLink   ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
  ipAddress      String
  userAgent      String?
  referer        String?
  country        String?
  city           String?
  isUnique       Boolean      @default(true)
  isSuspicious   Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Submission {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  campaignId       String            @db.ObjectId
  campaign         Campaign          @relation(fields: [campaignId], references: [id])
  influencerId     String            @db.ObjectId
  contentUrl       String
  socialPlatform   String            @default("YOUTUBE") // YOUTUBE, INSTAGRAM, TWITTER, FACEBOOK, TIKTOK
  contentType      String            @default("VIDEO") // VIDEO, POST, STORY, REEL, SHORT
  metrics          Json? // { views, likes, comments, shares, watchTime, etc. }
  validationStatus ValidationStatus  @default(PENDING)
  fraudFlags       String[]          @default([])
  adminNotes       String?
  validatedBy      String? // Admin user ID who validated
  validatedAt      DateTime?
  score            Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  leaderboardEntry LeaderboardEntry?
  metricsSnapshots MetricsSnapshot[]
  fraudAlerts      FraudAlert[]
}

model MetricsSnapshot {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  submissionId String     @db.ObjectId
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // Verified metrics from API
  views      Int
  likes      Int
  comments   Int
  shares     Int?
  engagement Float?

  // Verification metadata
  verifiedVia String // "YOUTUBE_API", "INSTAGRAM_API", "MANUAL"
  apiResponse Json? // Store raw API response for audit trail

  // Fraud detection results
  fraudScore Float?
  riskLevel  String? // LOW, MEDIUM, HIGH, CRITICAL
  fraudChecks Json? // Array of check results

  capturedAt DateTime @default(now())

  @@index([submissionId, capturedAt])
}

model FraudAlert {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  submissionId String     @db.ObjectId
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  alertType   String // "ENGAGEMENT_FRAUD", "GROWTH_SPIKE", "BOT_COMMENTS", etc.
  severity    String // LOW, MEDIUM, HIGH, CRITICAL
  description String
  evidence    Json // Detailed fraud indicators

  status       String    @default("PENDING") // PENDING, REVIEWED, CONFIRMED, DISMISSED
  reviewedBy   String?   @db.ObjectId
  reviewedAt   DateTime?
  reviewNotes  String?

  createdAt DateTime @default(now())

  @@index([status, severity])
  @@index([submissionId, createdAt])
}

model LeaderboardEntry {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  campaignId      String     @db.ObjectId
  campaign        Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submissionId    String     @unique @db.ObjectId
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  engagementScore Float      @default(0)
  referralScore   Float      @default(0)
  qualityScore    Float      @default(0)
  totalScore      Float      @default(0)
  rank            Int?
  prizeAmount     Float?
  scoreBreakdown  Json?
  isRevealed      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([campaignId, submissionId])
}

model InfluencerReport {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  influencerProfileId String            @db.ObjectId
  influencerProfile   InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)
  campaignId          String            @db.ObjectId
  contentQuality      Float?
  referralPerformance Json?
  suggestions         String[]
  generatedAt         DateTime          @default(now())
}

model BrandReport {
  id                 String       @id @default(auto()) @map("_id") @db.ObjectId
  brandProfileId     String       @db.ObjectId
  brandProfile       BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  campaignId         String       @db.ObjectId
  campaign           Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalReach         Int?
  totalEngagement    Int?
  totalReferrals     Int?
  totalConversions   Int?
  attributionData    Json?
  costPerAcquisition Float?
  roi                Float?
  topPerformers      Json?
  insights           String[]
  generatedAt        DateTime     @default(now())
}

model AdminAction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  performedBy   String   @db.ObjectId
  admin         User     @relation(fields: [performedBy], references: [id])
  actionType    String
  targetType    String
  targetId      String
  previousState Json?
  newState      Json?
  notes         String?
  createdAt     DateTime @default(now())
}